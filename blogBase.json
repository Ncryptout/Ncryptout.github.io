e, phin2)\nm = pow(c1, d2, shift)\nprint(long_to_bytes(m))\n\u2018\u2019\u2018\nb'42-b659-0c96ef827f05}'\n\u2019\u2018\u2019\n```\n\u672c\u6765\u5df2\u7ecf\u653e\u5f03\u8fd9\u9053\u9898\u4e86\uff0c\u4f46\u662f\u665a\u4e0a\u60f3\u4e86\u60f3vm\u7684\u53d6\u503c\u975e\u5e38\u6709\u9650\u53ef\u4ee5\u76f4\u63a5\u7206\u7834\n```python\nfrom Crypto.Util.number import *\nfrom math import log\nimport gmpy2\n\ne = 0x10001\ncipher1 = \ncipher2 = (, , 39796272592331896400626784951713239526857273168732133046667572399622660330587881579319314094557011554851873068389016629085963086136116425352535902598378739)\n\nfor v in range(2, 100000):\n    for m in range(int(log(2**1021, v)), int(log(2**1027, v))):\n        p = pow(v, m + 1) - pow(v + 1, m)\n        if isPrime(p) and 1021 < len(bin(p)) < 1027:\n            phin1 = p - 1\n            d1 = inverse(e, phin1)\n            m = pow(cipher1, d1, p)\n            if 'flag{' in str(long_to_bytes(m)):\n                print(str(long_to_bytes(m)))\n'''b'flag{8102c552-3d78-4a'\n2051'''\n```\n**\u628a\u8fd9\u79cd\u9898\u8bf4\u6210baby\u4e5f\u592a\u6076\u8da3\u5473\u4e86\uff01**\u3002", "top": 0, "createdAt": 1773214262, "style": "", "script": "", "head": "", "ogImage": "https://avatars.githubusercontent.com/u/261698442?v=4&size=64", "createdDate": "2026-03-11", "dateLabelColor": "#1f883d"}}, "singeListJson": {}, "labelColorDict": {"bug": "#d73a4a", "documentation": "#0075ca", "duplicate": "#cfd3d7", "enhancement": "#a2eeef", "good first issue": "#7057ff", "help wanted": "#008672", "invalid": "#e4e669", "question": "#d876e3", "wontfix": "#ffffff"}, "displayTitle": "\u6838\u6843\u7684\u535a\u5ba2", "faviconUrl": "https://avatars.githubusercontent.com/u/261698442?v=4&size=64", "ogImage": "https://avatars.githubusercontent.com/u/261698442?v=4&size=64", "primerCSS": "<link href='https://mirrors.sustech.edu.cn/cdnjs/ajax/libs/Primer/21.0.7/primer.css' rel='stylesheet' />", "homeUrl": "https://Ncryptout.github.io", "prevUrl": "disabled", "nextUrl":